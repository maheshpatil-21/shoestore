# ============================================
# ShoeStore Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=shoestore

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=shoestore_super_secret_jwt_key_change_me_2025
JWT_EXPIRES=7d
